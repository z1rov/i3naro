#!/usr/bin/env bash
set -e

echo "[+] Instalando paquetes VMware..."

sudo pacman -S --needed --noconfirm \
    xf86-video-vmware \
    open-vm-tools \
    xorg-xrandr

echo "[+] Activando servicios VMware..."

sudo systemctl enable --now vmtoolsd

echo "[+] Detectando pantalla..."

OUTPUT=$(xrandr | grep " connected" | cut -d" " -f1)

echo "[+] Pantalla detectada: $OUTPUT"

# buscar mejor resolución disponible
BEST_MODE=$(xrandr | grep -A1 "$OUTPUT connected" | \
    grep -oP '^[ ]+\K[0-9]+x[0-9]+' | tail -n 1)

if [ -z "$BEST_MODE" ]; then
    BEST_MODE="1920x1080"
fi

echo "[+] Aplicando resolución: $BEST_MODE"

xrandr --output "$OUTPUT" --mode "$BEST_MODE" || true

echo "[+] Configurando autostart en i3..."

mkdir -p ~/.config/i3

if ! grep -q "vmware-user" ~/.config/i3/config 2>/dev/null; then
cat <<EOF >> ~/.config/i3/config

# VMware auto resize
exec --no-startup-id vmware-user
exec --no-startup-id xrandr --output $OUTPUT --mode $BEST_MODE
EOF
fi

echo "[✔] Listo. Reinicia sesión o ejecuta: i3-msg restart"
